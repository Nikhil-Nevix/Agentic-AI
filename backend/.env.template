# === APPLICATION ===
APP_NAME=Service Desk Triaging Agent
APP_VERSION=1.0.0
ENVIRONMENT=development
DEBUG=true

# === DATABASE ===
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=your_mysql_password
MYSQL_DATABASE=service_desk_agent

# === LLM PROVIDERS ===
# Primary provider: openai | groq | gemini
LLM_PROVIDER=openai

# OpenAI (Primary)
OPENAI_API_KEY=enter_your_openai_api_key_here
OPENAI_MODEL=gpt-4o
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
OPENAI_TEMPERATURE=0.1

# Groq (Fallback A)
GROQ_API_KEY=enter_your_groq_api_key_here
GROQ_MODEL=llama-3.1-70b-versatile
GROQ_TEMPERATURE=0.1

# Gemini (Fallback B)
GOOGLE_API_KEY=enter_your_google_api_key_here
GEMINI_MODEL=gemini-1.5-flash
GEMINI_TEMPERATURE=0.1

# === EMBEDDINGS ===
# Embedding provider: openai | local
EMBEDDING_PROVIDER=openai
LOCAL_EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2

# === VECTOR STORE ===
FAISS_INDEX_PATH=./backend/data/faiss_index
FAISS_TICKET_INDEX=tickets.index
FAISS_SOP_INDEX=sop.index
FAISS_METADATA_FILE=metadata.json

# === RETRIEVAL ===
TOP_K_SIMILAR_TICKETS=5
TOP_K_SOP_CHUNKS=3
SIMILARITY_THRESHOLD=0.65

# === AGENT ===
MAX_AGENT_ITERATIONS=5
AGENT_TIMEOUT_SECONDS=60

# === CONFIDENCE ROUTING ===
AUTO_RESOLVE_THRESHOLD=0.85
HUMAN_ESCALATION_THRESHOLD=0.60

# === LANGSMITH (Optional) ===
LANGSMITH_TRACING=true
LANGCHAIN_API_KEY=ls__your-langsmith-api-key-here
LANGCHAIN_PROJECT=service-desk-agent
LANGCHAIN_ENDPOINT=https://api.smith.langchain.com

# === SECURITY ===
SECRET_KEY=your-secret-key-min-32-chars-for-jwt-signing
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# === CORS ===
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# === LOGGING ===
LOG_LEVEL=INFO
LOG_FILE=./backend/logs/app.log
LOG_ROTATION=10 MB
LOG_RETENTION=30 days
